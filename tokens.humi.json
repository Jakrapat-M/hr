  "spacing": {
    "$type": "dimension",
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 32,
        "unit": "px"
      }
    },
    "page-x": {
      "$value": {
        "value": 32,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "sm": {
      "$value": {
        "value": 10,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 14,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 20,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 28,
        "unit": "px"
      }
    },
    "full": {
      "$value": {
        "value": 9999,
        "unit": "px"
      }
    }
  },
  "typography": {
    "display-h1": {
      "$type": "typography",
      "$value": {
        "fontFamily": "CPN Condensed, CPN, Anuphan, ui-sans-serif, system-ui, sans-serif",
        "fontSize": {
          "value": 32,
          "unit": "px"
        },
        "fontWeight": 700,
        "letterSpacing": {
          "value": -0.01,
          "unit": "em"
        },
        "lineHeight": 40
      }
    },
    "display-h2": {
      "$type": "typography",
      "$value": {
        "fontFamily": "CPN Condensed, CPN, Anuphan, ui-sans-serif, system-ui, sans-serif",
        "fontSize": {
          "value": 24,
          "unit": "px"
        },
        "fontWeight": 600,
        "letterSpacing": {
          "value": -0.01,
          "unit": "em"
        },
        "lineHeight": 32
      }
    },
    "display-h3": {
      "$type": "typography",
      "$value": {
        "fontFamily": "CPN Condensed, CPN, Anuphan, ui-sans-serif, system-ui, sans-serif",
        "fontSize": {
          "value": 20,
          "unit": "px"
        },
        "fontWeight": 600,
        "lineHeight": 28
      }
    },
    "body": {
      "$type": "typography",
      "$value": {
