      "$value": {
        "fontFamily": "CPN, Anuphan, ui-sans-serif, system-ui, sans-serif",
        "fontSize": {
          "value": 13,
          "unit": "px"
        },
        "fontWeight": 400,
        "lineHeight": 20
      }
    },
    "eyebrow": {
      "$type": "typography",
      "$value": {
        "fontFamily": "CPN, Anuphan, ui-sans-serif, system-ui, sans-serif",
        "fontSize": {
          "value": 11,
          "unit": "px"
        },
        "fontWeight": 600,
        "letterSpacing": {
          "value": 0.14,
          "unit": "em"
        },
        "lineHeight": 16
      }
    },
    "mono": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Geist Mono, ui-monospace, Courier New, monospace",
        "fontSize": {
          "value": 13,
          "unit": "px"
        },
        "fontWeight": 500,
        "lineHeight": 20
      }
    }
